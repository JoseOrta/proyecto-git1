{"ops":[{"insert":"Semantic Versioning Specification (SemVer)"},{"attributes":{"header":2},"insert":"\n\n"},{"attributes":{"bold":true},"insert":"SemVer "},{"insert":"utiliza un formato de tres números: "},{"attributes":{"bold":true},"insert":"MAJOR.MINOR.PATCH"},{"insert":" (por ejemplo, tu actual "},{"attributes":{"bold":true},"insert":"1.1.3"},{"insert":")\n\n\n"},{"attributes":{"bold":true},"insert":"Primer número MAJOR"},{"insert":" (Mayor) Cuando haces cambios que "},{"attributes":{"bold":true},"insert":"rompen la compatibilidad"},{"insert":". El código viejo ya no funciona con el nuevo."},{"attributes":{"bold":true},"insert":"2.0.0"},{"insert":"\n\n"},{"attributes":{"bold":true},"insert":"Segundo número MINOR"},{"insert":" (Menor) Cuando añades "},{"attributes":{"bold":true},"insert":"funcionalidades nuevas"},{"insert":" pero mantienes la compatibilidad con lo anterior."},{"attributes":{"bold":true},"insert":"1.2.0"},{"insert":"\n\n"},{"attributes":{"bold":true},"insert":"Tercer número PATCH"},{"insert":" (Parche) Cuando solo haces "},{"attributes":{"bold":true},"insert":"correcciones de errores (bugs)"},{"insert":" o seguridad."},{"attributes":{"bold":true},"insert":"1.1.4"},{"insert":"\n\n\n"},{"attributes":{"bold":true},"insert":"Ejemplo Orta Note Lite - v1.1.2"},{"attributes":{"header":2},"insert":"\n"},{"insert":"Como "},{"attributes":{"bold":true},"insert":"Sysadmin"},{"insert":", sabemos que el versionado semántico es sagrado. Aquí te explico por qué este nombre es el correcto para tu registro en GitHub y el ejecutable:\n"},{"attributes":{"header":2},"insert":"\n"},{"attributes":{"bold":true},"insert":"v1"},{"insert":": Es la versión mayor (tu proyecto base funcional)."},{"attributes":{"list":"bullet"},"insert":"\n"},{"attributes":{"bold":true},"insert":"1"},{"insert":": Es la versión menor (has añadido funcionalidades nuevas como la barra de búsqueda)."},{"attributes":{"list":"bullet"},"insert":"\n"},{"attributes":{"bold":true},"insert":"2"},{"insert":": Es el \"patch\" o parche de estabilidad (hoy corregimos los bugs del resaltado persistente y el rebote del clic de la rueda)."},{"attributes":{"list":"bullet"},"insert":"\n"},{"insert":"\n"}]}